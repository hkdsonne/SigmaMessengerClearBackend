{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AspNetCoreRateLimit": "Information"
    }
  },

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/File/upload",
        "Period": "1m",
        "Limit": 500,
        "Message": "Слишком много попыток загрузки. Подождите 1 минуту."
      },
      {
        "Endpoint": "GET:/api/File/download/*",
        "Period": "1m",
        "Limit": 3000,
        "Message": "Слишком много скачиваний. Подождите 1 минуту."
      },
      {
        "Endpoint": "GET:/api/File/my-files",
        "Period": "1m",
        "Limit": 1000,
        "Message": "Слишком много запросов списка файлов."
      },
      {
        "Endpoint": "GET:/api/File/info/*",
        "Period": "1m",
        "Limit": 20000,
        "Message": "Слишком много запросов информации о файлах."
      },
      {
        "Endpoint": "GET:/api/File/temp-link/*",
        "Period": "1m",
        "Limit": 15000,
        "Message": "Слишком много запросов временных ссылок."
      },
      {
        "Endpoint": "DELETE:/api/File/*",
        "Period": "1m",
        "Limit": 100000,
        "Message": "Слишком много попыток удаления."
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100000,
        "Message": "Превышен лимит запросов. Подождите немного."
      }
    ]
  },

  "AuthService": {
    "Url": "http://localhost:5001"
  },

  "Ydb": {
    "Endpoint": "grpcs://ydb.serverless.yandexcloud.net:2135",
    "Database": "/ru-central1/b1g69pfp51gkvusl6ll7/etnjv3i8ke81qct0a2hi"
  },

  "YdbAuth": {
    "SaFilePath": "ydb_key.json"
  },

  "Security": {
    "MaxArchiveExtractSizeMB": 100,
    "AllowedMimeTypes": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "image/webp",
      "application/pdf",
      "text/plain",
      "application/json",
      "video/mp4",
      "audio/mpeg"
    ]
  },

  "AllowedHosts": "*",

  "ChatService": {
    "Url": "http://localhost:5002"
  }
}